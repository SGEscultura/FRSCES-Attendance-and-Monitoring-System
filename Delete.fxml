<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="750.0" spacing="20.0" style="-fx-background-color: #FAFFFC; -fx-background-radius: 30; -fx-border-color: #C0E1FC; -fx-border-radius: 20; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
   <children>
      <VBox alignment="CENTER" spacing="5.0">
         <children>
            <Label text="MANAGE DELETIONS" textFill="#b22222">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label text="Select a section to review students before removal" textFill="#666666" />
         </children>
      </VBox>

      <HBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-padding: 15; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);" VBox.vgrow="NEVER">
         <children>
            <Label text="Grade:" />
            <ComboBox fx:id="deleteFilterGrade" prefWidth="150.0" promptText="Select Grade" />
            <Label text="Section:" />
            <ComboBox fx:id="deleteFilterSection" prefWidth="150.0" promptText="Select Section" />
            <Button mnemonicParsing="false" onAction="#handleLoadRecords" style="-fx-background-color: #B4D5C3; -fx-cursor: hand;" text="Show Students" />
         </children>
         <effect>
            <InnerShadow />
         </effect>
      </HBox>

      <TableView fx:id="deleteTable" prefHeight="298.0" prefWidth="678.0" style="-fx-background-radius: 10;" VBox.vgrow="ALWAYS">
        <columns>
          <TableColumn fx:id="colDeleteName" minWidth="200.0" prefWidth="-1.0" text="Student Full Name" />
          <TableColumn fx:id="colDeleteID" minWidth="100.0" prefWidth="-1.0" text="Student ID" />
          <TableColumn fx:id="colDeleteContactNumber" minWidth="150.0" prefWidth="-1.0" text="Parent's Contact Number" />
        </columns>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>

      <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 10;" VBox.vgrow="NEVER">
         <children>
            <Label text="Individual ID:" />
            <TextField fx:id="deleteStudentID" promptText="Enter ID to delete" />
            <Button onAction="#handleDeleteIndividual" style="-fx-background-color: #ffd1d1;" text="Delete One" />
            <Button mnemonicParsing="false" onAction="#handleDeleteAllInSection" prefHeight="40.0" prefWidth="250.0" style="-fx-background-color: #FF6B6B; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand;" text="DELETE ALL IN THIS SECTION">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
