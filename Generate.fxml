<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="635.0" prefWidth="915.0"
            style="-fx-background-color: #F4F7F5; -fx-background-radius: 20;"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller">

   <children>
      <VBox alignment="TOP_CENTER" spacing="20.0"
            AnchorPane.topAnchor="20.0"
            AnchorPane.bottomAnchor="20.0"
            AnchorPane.leftAnchor="20.0"
            AnchorPane.rightAnchor="20.0">

         <children>
            <!-- TITLE -->
            <Label text="GENERATE STUDENT QR CODES" textFill="#2d5a4c">
               <font>
                  <Font name="System Bold" size="24.0"/>
               </font>
            </Label>

            <!-- FILTERS -->
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <ComboBox fx:id="genGradeBox"
                            prefHeight="35.0"
                            prefWidth="180.0"
                            promptText="Select Grade"
                            style="-fx-background-radius: 8;" />

                  <ComboBox fx:id="genSectionBox"
                            prefHeight="35.0"
                            prefWidth="180.0"
                            promptText="Select Section"
                            style="-fx-background-radius: 8;" />

                  <Button text="SEARCH"
                          prefHeight="35.0"
                          prefWidth="100.0"
                          mnemonicParsing="false"
                          onAction="#handleFilterStudents"
                          style="-fx-background-color: #2d5a4c;
                                 -fx-text-fill: white;
                                 -fx-background-radius: 8;">
                     <font>
                        <Font name="System Bold" size="12.0"/>
                     </font>
                  </Button>
               </children>
            </HBox>

            <!-- MAIN CONTENT -->
            <HBox spacing="20.0" VBox.vgrow="ALWAYS">
               <children>

                  <!-- TABLE -->
                  <TableView fx:id="genStudentTable"
                             prefWidth="550.0"
                             HBox.hgrow="ALWAYS">

                     <columns>
                        <TableColumn fx:id="colGenName"
                                     text="STUDENT NAME"
                                     prefWidth="350.0"
                                     style="-fx-alignment: CENTER-LEFT;" />

                        <TableColumn fx:id="colAction"
                                     text="ACTION"
                                     prefWidth="150.0"
                                     style="-fx-alignment: CENTER;" />
                     </columns>

                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                     </columnResizePolicy>
                  </TableView>

                  <!-- QR PREVIEW -->
                  <VBox alignment="CENTER"
                        minWidth="300.0"
                        maxWidth="300.0"
                        spacing="15.0"
                        style="-fx-background-color: white;
                               -fx-padding: 20;
                               -fx-background-radius: 15;
                               -fx-border-color: #E0E0E0;
                               -fx-border-radius: 15;">

                     <children>
                        <Label text="QR CODE PREVIEW" textFill="#777777">
                           <font>
                              <Font name="System Bold" size="12.0"/>
                           </font>
                        </Label>

                        <ImageView fx:id="imgQrCode"
                                   fitHeight="200.0"
                                   fitWidth="200.0"
                                   preserveRatio="true"
                                   pickOnBounds="true"/>

                        <Button text="DOWNLOAD IMAGE"
                                prefHeight="35.0"
                                prefWidth="200.0"
                                mnemonicParsing="false"
                                onAction="#handleDownloadQR"
                                textFill="WHITE"
                                style="-fx-background-color: #2d5a4c;
                                       -fx-background-radius: 10;">
                           <font>
                              <Font name="System Bold" size="12.0"/>
                           </font>
                        </Button>
                     </children>

                     <effect>
                        <InnerShadow/>
                     </effect>
                  </VBox>
               </children>
            </HBox>

            <!-- BACK BUTTON -->
            <Button text="BACK"
                    prefHeight="40.0"
                    prefWidth="150.0"
                    mnemonicParsing="false"
                    onAction="#handleCancel"
                    textFill="WHITE"
                    style="-fx-background-color: #FF6961;
                           -fx-background-radius: 12;">
               <font>
                  <Font name="System Bold" size="14.0"/>
               </font>
            </Button>

         </children>
      </VBox>
   </children>

   <effect>
      <DropShadow/>
   </effect>

</AnchorPane>