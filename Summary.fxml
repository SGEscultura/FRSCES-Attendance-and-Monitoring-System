<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="850.0" spacing="15.0" style="-fx-background-color: #F4F7F6;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller">
   <children>

      <!-- HEADER -->
      <VBox spacing="5.0" style="-fx-background-color: #2D5A43; -fx-background-radius: 15; -fx-padding: 20;">
         <children>
            <Label text="Attendance Analytics" textFill="WHITE">
               <font><Font name="System Bold" size="28.0" /></font>
            </Label>
            <Label text="Monthly summary report per Section by Grade Level" textFill="#b4d5c3">
               <font><Font size="14.0" /></font>
            </Label>
         </children>
      </VBox>

      <!-- FILTERS -->
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="Month" textFill="#666666" />
                  <ComboBox fx:id="summaryMonth" prefHeight="35.0" prefWidth="140.0" promptText="Select Month" style="-fx-background-color: #F4F7F6; -fx-background-radius: 8;" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label text="Year" textFill="#666666" />
                  <ComboBox fx:id="summaryYear" prefHeight="35.0" prefWidth="90.0" promptText="Year" style="-fx-background-color: #F4F7F6; -fx-background-radius: 8;" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label text="Grade Level" textFill="#666666" />
                  <ComboBox fx:id="summaryGrade" prefHeight="35.0" prefWidth="140.0" promptText="Select Grade" style="-fx-background-color: #F4F7F6; -fx-background-radius: 8;" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label text="Section" textFill="#666666" />
                  <ComboBox fx:id="summarySection" prefHeight="35.0" prefWidth="140.0" promptText="Select Section" style="-fx-background-color: #F4F7F6; -fx-background-radius: 8;" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleGenerateReport" prefHeight="40.0" prefWidth="120.0" style="-fx-background-color: #B4D5C3; -fx-background-radius: 10; -fx-text-fill: #2D5A43; -fx-cursor: hand;" text="GENERATE">
               <font><Font name="System Bold" size="13.0" /></font>
               <HBox.margin><Insets top="18.0" /></HBox.margin>
            </Button>
         </children>
      </HBox>

      <!-- GRAPH LEFT (SMALLER) + TABLE RIGHT (BIGGER) -->
      <HBox spacing="15.0" VBox.vgrow="ALWAYS">
         <children>

            <!-- BAR CHART (LEFT) — smaller fixed width -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" prefWidth="320.0">
               <children>
                  <Label text="Daily Attendance Flow" textFill="#2D5A43">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <BarChart fx:id="attendanceChart" alternativeColumnFillVisible="true" legendSide="BOTTOM" VBox.vgrow="ALWAYS">
                    <xAxis>
                      <CategoryAxis label="Day of Month" side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                      <NumberAxis label="Headcount" side="LEFT" />
                    </yAxis>
                  </BarChart>
               </children>
            </VBox>

            <!-- STUDENT TABLE (RIGHT) — bigger, grows -->
            <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 15;" HBox.hgrow="ALWAYS">
               <children>
                  <Label text="Student Attendance Summary" textFill="#2D5A43">
                     <font><Font name="System Bold" size="14.0" /></font>
                  </Label>
                  <TableView fx:id="summaryTable" VBox.vgrow="ALWAYS" maxWidth="1.7976931348623157E308">
                     <columns>
                        <TableColumn fx:id="colSummaryName"    prefWidth="200.0" text="Student Name" />
                        <TableColumn fx:id="colSummaryID"      prefWidth="100.0" text="Student ID" />
                        <TableColumn fx:id="colSummaryPresent" prefWidth="100.0" text="Present Days" />
                        <TableColumn fx:id="colSummaryAbsent"  prefWidth="100.0" text="Absent Days" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>

         </children>
      </HBox>

   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
