                  <Button mnemonicParsing="false" onAction="#handleSaveChanges" prefHeight="40.0" prefWidth="160.0" style="-fx-background-color: #2d5a43; -fx-text-fill: white; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 0);" text="SAVE CHANGES" />
